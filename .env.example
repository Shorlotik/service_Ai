# ML Provider Configuration
# Options: local, huggingface, openai
ML_PROVIDER=local

# Local Model Configuration (required if ML_PROVIDER=local)
LOCAL_MODEL_URL=http://localhost:8000/predict

# Hugging Face Configuration (required if ML_PROVIDER=huggingface)
# Get your API key from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
HUGGINGFACE_API_URL=https://api-inference.huggingface.co/models

# OpenAI Configuration (required if ML_PROVIDER=openai)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# Cache Configuration
# Options: memory, redis
CACHE_STRATEGY=memory
# Cache TTL in seconds (default: 86400 = 24 hours)
CACHE_TTL=86400

# Redis Configuration (required if CACHE_STRATEGY=redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Redis password (optional, leave empty if not needed)
REDIS_PASSWORD=

# API Configuration
# Timeout for ML API requests in seconds
API_TIMEOUT=30
# Maximum text length for classification
MAX_TEXT_LENGTH=10000

# Response Format
# Options: simple, detailed
RESPONSE_FORMAT=simple

# Logging Configuration
# Options: simple, json
LOG_FORMAT=simple
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Application Configuration
APP_NAME=ML API Wrapper Service
APP_VERSION=1.0.0
